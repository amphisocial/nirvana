+.assistant-messages .message { max-width: 94%; font-size: .86rem; }
+.assistant-input {
+  margin-top: .75rem;
+  display: grid;
+  grid-template-columns: 1fr 42px;
+  gap: .45rem;
+  align-items: end;
+  border: 1px solid #d8e3de;
+  background: white;
+  border-radius: 12px;
+  padding: .45rem;
+}
+.assistant-input textarea {
+  border: 0;
+  box-shadow: none;
+  resize: none;
+}
+.assistant-send {
+  width: 40px;
+  height: 40px;
+  border: 0;
+  border-radius: 50%;
+  background: var(--nirvana-deep);
+  color: white;
+  cursor: pointer;
+}
+.assistant-disclaimer {
+  color: var(--ink-soft);
+  font-size: .68rem;
+  margin: .5rem 0 0;
+  text-align: center;
+}
+@media (min-width: 1500px) {
+  .assistant-drawer.open ~ * {}
+  body.assistant-open .app-main { margin-right: 390px; transition: margin-right .24s ease; }
+}
+@media (max-width: 760px) {
+  .assistant-toggle { display: none; }
+  .assistant-drawer { width: 100vw; }
+}
+
+/* Retirement cash-flow planner */
+.metric-grid-five { grid-template-columns: repeat(5, minmax(0, 1fr)); }
+.retirement-metric-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); }
+.stack-form label > small { color: var(--ink-soft); font-weight: 500; line-height: 1.35; }
+.check-label {
+  display: flex !important;
+  grid-template-columns: auto 1fr;
+  align-items: center;
+  gap: .55rem !important;
+  min-height: 42px;
+  padding: .65rem .75rem;
+  border: 1px solid var(--line);
+  border-radius: 10px;
+  background: white;
+}
+.check-label input { width: auto; margin: 0; }
+.cashflow-list { display: grid; gap: .2rem; }
+.cashflow-row {
+  display: grid;
+  grid-template-columns: minmax(0, 1fr) auto;
+  gap: 1rem;
+  align-items: center;
+  padding: .85rem 0;
+  border-bottom: 1px solid var(--line);
+}
+.cashflow-row > div:first-child { min-width: 0; }
+.cashflow-row strong, .cashflow-row small { display: block; }
+.cashflow-row small { color: var(--ink-soft); margin-top: .18rem; text-transform: capitalize; }
+.cashflow-row-trailing { display: grid; justify-items: end; gap: .45rem; }
+.cashflow-row-trailing > strong { white-space: nowrap; font-family: Georgia, serif; }
+.retirement-age-table { max-height: 390px; overflow-y: auto; }
+.feasible-row { background: #eaf8f1; }
+.feasible-row td { color: var(--nirvana-deep); }
+#propertyReleaseFields { display: grid; gap: .85rem; }
+#propertyReleaseFields.hidden { display: none !important; }
+#postRetirementExpenseFields.hidden { display: none !important; }
+
+@media (max-width: 1320px) {
+  .metric-grid-five { grid-template-columns: repeat(3, minmax(0, 1fr)); }
+  .retirement-metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+}
+@media (max-width: 900px) {
+  .metric-grid-five, .retirement-metric-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
+}
+@media (max-width: 620px) {
+  .metric-grid-five, .retirement-metric-grid { grid-template-columns: 1fr; }
+  .cashflow-row { grid-template-columns: 1fr; }
+  .cashflow-row-trailing { justify-items: start; }
+}
+.derived-badge {
+  display: inline-flex;
+  align-items: center;
+  padding: .28rem .55rem;
+  border-radius: 999px;
+  background: var(--accent-pale);
+  color: var(--accent-dark);
+  font-size: .7rem;
+  font-weight: 800;
+}
