# Application
NODE_ENV=development
PORT=5015
APP_URL=http://localhost:5015
SESSION_SECRET=replace-with-a-long-random-secret
LOG_LEVEL=info
DEMO_MODE=true
TRUST_PROXY=1

# PostgreSQL
DATABASE_URL=postgresql://nirvana:nirvana@127.0.0.1:5432/nirvana
DATABASE_SSL=false
DB_POOL_MAX=10

# Authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5015/auth/google/callback

# AI provider: openai | gemini | anthropic | mock
AI_PROVIDER=mock
AI_MODEL=gpt-5-mini
AI_MAX_OUTPUT_TOKENS=1600
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_VERSION=2023-06-01
AI_WEB_SEARCH_ENABLED=true
AI_WEB_SEARCH_CONTEXT_SIZE=medium
AI_SKILLS_DIR=server/skills
AI_ENABLED_SKILLS=personal-finance-coach,retirement-planner,stock-market-analyst,portfolio-scenario-analyst,financial-intelligence-agent,real-estate-scenario-analyst
AI_SYSTEM_MODE=research_only
ALLOW_PERSONALIZED_RECOMMENDATIONS=false
ALLOW_TRADE_EXECUTION=false

# Market data provider: alphavantage | mock
MARKET_DATA_PROVIDER=mock
ALPHAVANTAGE_API_KEY=
MARKET_CACHE_MINUTES=30
MARKET_RESEARCH_CACHE_MINUTES=720
MARKET_NEWS_CACHE_MINUTES=30
MARKET_NEWS_LIMIT=8
MARKET_DATA_DELAY_NOTICE=Market data may be delayed or incomplete. Verify prices with your broker before acting.

# Scheduled agents
# Defaults to enabled automatically when NODE_ENV=production.
AGENT_SCHEDULER_ENABLED=false
AGENT_TIMEZONE=America/New_York
# Nightly state snapshot and From Nirvana's Desk article.
AGENT_NIGHTLY_HOUR=2
# Sunday=0, Monday=1, ... Saturday=6.
AGENT_WEEKLY_DAY=0
# Weekly forecast/research/drift run starts after the nightly run.
AGENT_WEEKLY_HOUR=3
AGENT_MAX_SYMBOLS_PER_RUN=250
AGENT_DRIFT_THRESHOLD_PCT=5
AGENT_LARGE_EXPENSE_THRESHOLD=1000

# Agentic Trading Desk (premium, admin-gated per household)
# Per-household on/off lives in the trading_desk_settings table and is toggled
# by the household owner in-app (Holdings -> Trading Desk -> Settings). These
# flags are global operational controls only:
TRADING_DESK_SCHEDULER_ENABLED=true
TRADING_DESK_MAX_LIVE_SYMBOLS=24

# Plaid
ACCOUNT_AGGREGATION_MODE=manual
PLAID_ENABLED=false
PLAID_ENV=sandbox
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_PRODUCTS=transactions,investments,liabilities
PLAID_COUNTRY_CODES=US
PLAID_WEBHOOK_URL=https://nirvana.athenabot.ai/api/plaid/webhook
PLAID_REDIRECT_URI=https://nirvana.athenabot.ai/plaid/oauth-return
TOKEN_ENCRYPTION_KEY=

# Stripe
STRIPE_ENABLED=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_SUCCESS_URL=https://nirvana.athenabot.ai/app.html?billing=success
STRIPE_CANCEL_URL=https://nirvana.athenabot.ai/app.html?billing=cancelled

# Security / compliance messaging
FINANCIAL_DISCLAIMER_TITLE=Educational research only
FINANCIAL_DISCLAIMER_TEXT=These results are generated by automated models and may be incomplete, delayed, or wrong. They are educational and are not investment, tax, legal, or retirement advice. Consult a qualified professional before making financial decisions.
