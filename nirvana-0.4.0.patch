+.assistant-toggle { border-color: #bfd8ed; color: var(--blue-dark); }
+.feasible-row { background: #e8f3fd; }
+.feasible-row td { color: var(--blue-dark); }
+.debt-balance, .row-action.danger { color: var(--blue-slate); }
+.row-action.danger:hover { border-color: var(--blue-slate); background: #edf4fa; }
+
+/* Collapsible desktop navigation */
+.sidebar, .app-main, .brand-label, .nav-label, .mini-status-copy { transition: width .22s ease, margin-left .22s ease, opacity .16s ease; }
+.sidebar-brand-row { display: flex; align-items: center; justify-content: space-between; gap: .5rem; margin-bottom: 1rem; }
+.brand-sidebar { padding: 0 .35rem; min-width: 0; overflow: hidden; white-space: nowrap; }
