+.forecast-metrics { display: grid; grid-template-columns: repeat(3, 1fr); gap: .65rem; margin-bottom: .8rem; }
+.forecast-metrics div { background: var(--surface-soft); border-radius: 10px; padding: .8rem; }
+.forecast-metrics span, .forecast-metrics strong { display: block; }
+.forecast-metrics span { color: var(--ink-soft); font-size: .7rem; }
+.forecast-metrics strong { margin-top: .25rem; color: var(--blue-dark); }
+.holdings-manager { max-height: 390px; margin-top: .9rem; overflow-y: auto; }
+.holdings-manager td:last-child { display: flex; justify-content: flex-end; gap: .3rem; }
+.compact-form { padding: .9rem; border: 1px solid var(--line); border-radius: 12px; background: #fbfdff; }
+.account-row-details small { line-height: 1.45; }
+
+@media (max-width: 1100px) {
+  .projected-net-worth-layout { grid-template-columns: 1fr; }
+  .projection-summary-column { border-right: 0; border-bottom: 1px solid var(--line); padding-right: 0; padding-bottom: 1rem; display: grid; grid-template-columns: 1fr 1fr; }
+  .projection-flow-summary { grid-column: 1 / -1; }
+  .portfolio-toolbar { grid-template-columns: 1fr; }
+  .forecast-metrics { grid-template-columns: 1fr 1fr 1fr; }
+}
+@media (max-width: 760px) {
+  .sidebar-toggle { display: none; }
+  body.sidebar-collapsed .sidebar { width: auto; padding: .8rem; }
+  body.sidebar-collapsed .app-main { margin-left: 0; }
+  body.sidebar-collapsed .brand-label,
+  body.sidebar-collapsed .nav-label { width: auto; opacity: 1; }
+  .sidebar-brand-row { justify-content: flex-start; }
+  .nav-item { justify-content: center; gap: .25rem; }
+  .nav-icon { display: none; }
+  .projected-net-worth-layout, .projection-summary-column { grid-template-columns: 1fr; }
+  .forecast-metrics { grid-template-columns: 1fr; }
+  .portfolio-actions { width: 100%; }
+  .portfolio-actions .button { flex: 1; }
+}
