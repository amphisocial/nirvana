+  --nirvana-canvas: #f5f9fd;
+}
+body, .app-body { background: var(--paper); color: var(--ink); }
+.sidebar { background: linear-gradient(180deg, #0b3a67 0%, #0d477c 100%); }
+.panel, .metric-card, .hero-panel {
+  background: #fff;
+  border-color: var(--line);
+  box-shadow: var(--shadow);
+}
+.metric-featured, .button-primary, .user-message, .assistant-send, .assistant-fab {
+  background: var(--blue-dark);
+  color: #fff;
+}
+.button-primary:hover { background: #0f528f; }
+.panel-kicker, .eyebrow, .text-link, .text-button { color: var(--blue); }
+.status-pill { background: var(--blue-pale); color: var(--blue-dark); }
+.status-dot { background: #8cc8ff; box-shadow: 0 0 0 4px rgba(140, 200, 255, .15); }
+input:focus, select:focus, textarea:focus { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(25, 118, 197, .12); }
+.investment-profile, .payment-breakdown, .info-callout {
+  border: 1px solid #c8dff1;
+  background: linear-gradient(145deg, #f8fbff, #eaf4fd);
+  border-radius: 12px;
+  padding: 1rem;
+}
+.info-callout { color: var(--ink-soft); font-size: .82rem; }
+.file-drop { border-color: var(--blue); background: var(--blue-pale); }
+.disclaimer-box { background: #edf5fc; }
+.chat-messages, .assistant-messages { background: #f7fbff; border-color: var(--line); }
+.assistant-drawer { background: #fff; border-color: var(--line); box-shadow: -20px 0 55px rgba(11, 58, 103, .15); }
